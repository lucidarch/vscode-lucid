{
    "Lucid Job": {
        "prefix": "lucid-job",
        "scope": "php",
        "description": "Scaffold a Lucid Job class",
        "body": [
            "<?php",
            "",
            "namespace App\\Domains\\${1:Domain}\\Jobs;",
            "",
            "use Lucid\\Units\\Job;",
            "",
            "class ${2:Name}Job extends Job",
            "{",
            "    public function __construct(",
            "        private readonly ${3:string} \\$${4:param},",
            "    ) {}",
            "",
            "    public function handle(): ${5:void}",
            "    {",
            "        $0",
            "    }",
            "}"
        ]
    },

    "Lucid Queueable Job": {
        "prefix": "lucid-qjob",
        "scope": "php",
        "description": "Scaffold a queueable Lucid Job class",
        "body": [
            "<?php",
            "",
            "namespace App\\Domains\\${1:Domain}\\Jobs;",
            "",
            "use Lucid\\Units\\Job;",
            "use Illuminate\\Contracts\\Queue\\ShouldQueue;",
            "",
            "class ${2:Name}Job extends Job implements ShouldQueue",
            "{",
            "    public function __construct(",
            "        private readonly ${3:string} \\$${4:param},",
            "    ) {}",
            "",
            "    public function handle(): ${5:void}",
            "    {",
            "        $0",
            "    }",
            "}"
        ]
    },

